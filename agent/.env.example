# ============================================================================
# LLM Provider — uncomment ONE provider block below
# ============================================================================

# --- MiniMax M3 Token Plan (active) ---
LANGCHAIN_PROVIDER=minimax
LANGCHAIN_MODEL_NAME=MiniMax-M3           # global default (deep seats inherit)
MINIMAX_API_KEY=<SUBSCRIPTION_KEY>        # Token Plan Subscription Key
# Path A (OpenAI-compatible /v1; works with pay-as-you-go keys):
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Path B (Anthropic-compatible; use if the Subscription Key is /anthropic-only).
# Selected automatically when MINIMAX_BASE_URL contains "/anthropic".
# Requires the optional adapter: pip install "vibe-trading-ai[minimax]"
# MINIMAX_BASE_URL=https://api.minimax.io/anthropic
# Optional: disable M3 thinking for a quick tier (default: adaptive).
# MINIMAX_THINKING=disabled
# Optional: max output tokens for the Path B (Anthropic) adapter (default: 4096).
# MINIMAX_MAX_TOKENS=4096

# --- OpenRouter (multi-model gateway) ---
# LANGCHAIN_PROVIDER=openrouter
# LANGCHAIN_MODEL_NAME=deepseek/deepseek-v4-pro
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- OpenAI ---
# LANGCHAIN_PROVIDER=openai
# LANGCHAIN_MODEL_NAME=gpt-5.5-instant
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- OpenAI Codex (ChatGPT OAuth; not the OpenAI API key path) ---
# Login first: vibe-trading provider login openai-codex
# Requires a ChatGPT account with Codex access. OAuth tokens are stored by oauth-cli-kit.
# LANGCHAIN_PROVIDER=openai-codex
# LANGCHAIN_MODEL_NAME=openai-codex/gpt-5.3-codex
# OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex/responses

# --- DeepSeek (rollback path from MiniMax) ---
# LANGCHAIN_PROVIDER=deepseek
# LANGCHAIN_MODEL_NAME=deepseek-v4-pro
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# IMPORTANT: rolling back is not just a provider swap — also restore the frozen
# DeepSeek baseline LLM parameters below, or DeepSeek silently runs at MiniMax's
# values and the A/B baseline comparison is invalid. Uncomment together with
# this block and comment out the MiniMax values under "LLM parameters":
# LANGCHAIN_TEMPERATURE=0.0                 # frozen baseline (MiniMax uses 1.0)
# Also restore TIMEOUT_SECONDS=120 and MAX_RETRIES=2 (the upstream baseline
# defaults; MiniMax raised them to 180 / 4 for M3's longer thinking turns).
# DeepSeek adapter selection: auto (default; use langchain-deepseek if installed),
# native (require langchain-deepseek, error if missing), or openai-compatible
# (force the legacy ChatOpenAI path). Install the adapter with:
# pip install "vibe-trading-ai[deepseek]"
# VIBE_TRADING_DEEPSEEK_ADAPTER=auto

# --- Gemini ---
# LANGCHAIN_PROVIDER=gemini
# LANGCHAIN_MODEL_NAME=gemini-3.5-flash
# GEMINI_API_KEY=xxx
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- Groq ---
# LANGCHAIN_PROVIDER=groq
# LANGCHAIN_MODEL_NAME=meta-llama/llama-4-maverick-17b-128e-instruct
# GROQ_API_KEY=gsk_xxx
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- DashScope / Qwen ---
# LANGCHAIN_PROVIDER=dashscope
# LANGCHAIN_MODEL_NAME=qwen-plus-latest
# DASHSCOPE_API_KEY=sk-xxx
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Zhipu ---
# LANGCHAIN_PROVIDER=zhipu
# LANGCHAIN_MODEL_NAME=glm-5.1
# ZHIPU_API_KEY=xxx
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- Moonshot / Kimi ---
# LANGCHAIN_PROVIDER=moonshot
# LANGCHAIN_MODEL_NAME=kimi-k2.6
# MOONSHOT_API_KEY=sk-xxx
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# --- Xiaomi MIMO ---
# LANGCHAIN_PROVIDER=mimo
# LANGCHAIN_MODEL_NAME=MiMo-72B-A27B
# MIMO_API_KEY=xxx
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# --- Z.ai (for Coding Plan) ---
# LANGCHAIN_PROVIDER=zai
# LANGCHAIN_MODEL_NAME=glm-5.1
# ZAI_API_KEY=xxx
# ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# --- Ollama (local) ---
# LANGCHAIN_PROVIDER=ollama
# LANGCHAIN_MODEL_NAME=qwen2.5:32b
# OLLAMA_BASE_URL=http://localhost:11434

# LLM parameters
LANGCHAIN_TEMPERATURE=1.0                 # MiniMax requires > 0; M3 default
TIMEOUT_SECONDS=180                       # M3 thinking turns run long
MAX_RETRIES=4                             # SDK-level; throttle window ≈ 1 min

# ---- Concurrency governance (Phase 2 §4) ----
# Process-wide hard ceiling on simultaneous in-flight LLM requests, enforced at
# the single ChatLLM chokepoint (every swarm worker, the main agent, and
# context compaction pass through it). 0 = disabled (upstream behavior). The
# MiniMax Plus tier supports ~3 concurrent agents, so 3 is the safe default.
VIBE_LLM_MAX_CONCURRENT=3
# Throttle-aware stream retry: capped exponential backoff + jitter, honoring
# Retry-After. base 2s, factor 2, cap 90s (covers MiniMax's ~1-min throttle).
# VT_STREAM_RETRY_MAX=5
# VT_STREAM_RETRY_BASE_S=2
# Observability only: log a warning when a single run burns more than this many
# tokens (unset / 0 = no warning). No hard cutoff — a throttled wait beats a
# mid-pipeline abort.
# VIBE_RUN_TOKEN_BUDGET_WARN=3000000

# ---- Model tiering (Phase 3) ----
# Provider-agnostic quick/deep model tiers for swarm presets (e.g.
# crypto_committee.yaml), resolved from ${VIBE_DEEP_MODEL}/${VIBE_QUICK_MODEL}
# placeholders in each seat's model_name at preset-build time. Unset -> that
# seat falls back to the run's global model (LANGCHAIN_MODEL_NAME above),
# preserving upstream behavior. Overrides must stay on the same provider as
# LANGCHAIN_PROVIDER (model_name only substitutes the model string).
# VIBE_DEEP_MODEL=MiniMax-M3                # research manager + portfolio manager
# VIBE_QUICK_MODEL=MiniMax-M2.7-highspeed   # analysts / debators / trader / risk
# Optional utility tier: routes AgentLoop._auto_compact (context summarization)
# through a cheaper same-provider model. Unset -> uses the main model (unchanged).
# VIBE_COMPACT_MODEL=MiniMax-M2.5-highspeed

# ---- Debate depth (Phase 4) ----
# Multi-round adversarial debate for swarm presets (e.g. crypto_committee.yaml).
# Rounds are unrolled into chained DAG tasks at preset-build time — the engine
# stays single-pass and acyclic; deeper debates only add wall-time (serial
# chain), never concurrency pressure on the 3-slot budget. Rounds are capped at
# 4 and rejected above that at build time. UNSET -> both default to 1, which
# reproduces the historical single-pass graph exactly (bull -> bear -> manager;
# risky -> safe -> neutral). Recommended: VIBE_DEBATE_ROUNDS=2 for a real
# two-round bull/bear exchange (bear responds to the bull's NEW round-2
# material, and the research manager cites both rounds).
# VIBE_DEBATE_ROUNDS=2                      # bull/bear rounds (1 = current behavior)
# VIBE_RISK_ROUNDS=1                        # risk-rotation rounds (risky/safe/neutral x N)

# ---- Learning loop (committee decision journal) ----
# Crypto benchmark the committee journal computes alpha against (default:
# BTC-USDT, crypto's SPY). The alpha calc always fetches via the loader
# registry (okx -> ccxt) regardless of this being set; unset -> BTC-USDT.
# VIBE_COMMITTEE_BENCHMARK=BTC-USDT
# Register a daily scheduled-research job that runs decision_journal
# action=resolve_due then action=reflect, so 24h/72h/7d outcomes resolve and
# lessons accrue even on days with no committee run (default OFF — today,
# resolution only happens when the next committee run's reflection officer
# fires). This is the same scheduler flag the wider scheduled-research
# subsystem uses (agent/src/scheduled_research/); enabling it also turns on
# any other scheduled research jobs you've created via POST /scheduled-runs.
# If you keep this off, run the equivalent from system cron instead — see
# docs/minimax-migration-notes.md (Phase 6) for the exact `vibe-trading run`
# command.
# VIBE_TRADING_ENABLE_SCHEDULER=1
# Experiment knob (default OFF): also inject the reflection officer's
# past_lessons block into the research_manager seat, not just the portfolio
# manager. TradingAgents deliberately restricts reflection/memory context to
# the PM — only flip this on to A/B test broader lesson visibility.
# VIBE_LESSONS_TO_MANAGER=1

# ---- Paper-trading loop (committee decision -> paper broker -> ledger -> PnL-aware reflection) ----
# Kill switch for the whole paper executor (the post-journal execution hook,
# the translator, and the scheduled daily tick all read this). Truthiness:
# UNSET means ENABLED; "0" / "false" / "" (case-insensitive) means disabled.
# Active on this branch per the design spec (docs/superpowers/specs/2026-07-11-paper-trading-loop-design.md §5).
VIBE_PAPER_ENABLED=1
# Paper USDT balance at account creation only; `vibe-trading paper reset --confirm`
# archives the old state and recreates at this balance.
# VIBE_PAPER_START_CASH=100000
# Market-fill slippage against the trader: buy fill = price*(1+bps/10000);
# sell fill = price*(1-bps/10000). Conditional stop/take-profit fills carry
# NO slippage (bar prices are already conservative) — only market orders pay it.
# VIBE_PAPER_SLIPPAGE_BPS=5
# Taker fee on notional, deducted from cash on every fill (market AND conditional).
# VIBE_PAPER_FEE_BPS=10
# Mandate: max concurrent open positions. Hard-rejects opening a NEW symbol at
# the cap (adding to an already-held symbol is unaffected).
# VIBE_PAPER_MAX_POSITIONS=3
# Mandate: max % of current equity a single symbol may hold. A buy that would
# exceed it is CLAMPED to the remaining headroom (not rejected); zero headroom
# IS a rejection (logged as a ledger noop, permanently skipped on retry).
# VIBE_PAPER_MAX_SYMBOL_PCT=25
# Entry size (% of equity) when a Buy/Overweight decision omits the typed
# position_size_pct field. Overweight always sizes at HALF whatever this
# resolves to.
# VIBE_PAPER_DEFAULT_SIZE_PCT=10
# Stop-loss distance (% below fill) when a Buy/Overweight decision omits the
# typed stop_loss field.
# VIBE_PAPER_DEFAULT_STOP_PCT=8
# State dir override (tests point this at a tmp dir); default ~/.vibe-trading/paper.
# VIBE_PAPER_ROOT=~/.vibe-trading/paper
# Tick cadence. 1D (default) = one confirmed daily bar per position, exactly the
# original behavior (no tick_state.json is created). 1H = intraday mode: each
# tick evaluates every confirmed 1H bar since a persisted per-symbol watermark,
# shrinking the unprotected entry window from <=1 day to <=1 hour.
# VIBE_PAPER_TICK_INTERVAL=1D
# Cron for the scheduled paper-trading-tick job's INITIAL registration only
# (default "30 0 * * *"; non-clobbering — changing this never rewrites an
# existing job). Recommended 2-hourly intraday deployment:
#   VIBE_PAPER_TICK_SCHEDULE="30 */2 * * *"
#   VIBE_PAPER_TICK_INTERVAL=1H
# VIBE_PAPER_TICK_SCHEDULE=30 0 * * *
# See docs/crypto-committee.md "Paper-trading loop" section for the
# end-to-end flow, the honest-limits paragraph (synthetic fills, flat
# slippage model, daily-bar approximation, long-only v1), and how to read
# `vibe-trading paper status`.

# ---- Scheduled committee runs (two-tier-cadence Task 2) ----
# Register a scheduled job (id "committee-run") that runs the FULL 13-seat
# crypto_committee swarm on its own cadence, independent of ad-hoc runs.
# Unset (default) = no job registered at all — this is the expensive tier,
# so unlike the reflection/paper-tick jobs above there is no built-in
# default schedule. Requires VIBE_TRADING_ENABLE_SCHEDULER=1 (same gate as
# every other scheduled-research job). VIBE_COMMITTEE_SYMBOLS and
# VIBE_COMMITTEE_TIMEFRAME below are read ONCE, at the moment this job is
# first registered, and baked into its prompt text; because registration is
# non-clobbering (a restart never rewrites an existing job), changing either
# env afterward has no effect until you delete the job (or hand-edit its
# persisted prompt) so a restart re-registers it with the new values.
# Recommended daily cadence, one committee run per symbol at 08:00 UTC:
#   VIBE_COMMITTEE_SCHEDULE="0 8 * * *"
#   VIBE_COMMITTEE_SYMBOLS=BTC-USDT,ETH-USDT
#   VIBE_COMMITTEE_TIMEFRAME="72h swing"
# VIBE_COMMITTEE_SCHEDULE=0 8 * * *
# Comma-separated loader-format symbols, in the order they are analyzed
# (serially, one crypto_committee run each). Default when unset: BTC-USDT.
# Loader-format HYPHENATED symbols are required: BTC-USDT — not BTC, not BTCUSDT.
# VIBE_COMMITTEE_SYMBOLS=BTC-USDT,ETH-USDT
# Decision horizon passed to every symbol's run this job registers.
# VIBE_COMMITTEE_TIMEFRAME=72h swing
# See docs/crypto-committee.md "Cadence" section for the recommended
# two-tier deployment (this job for the full committee + the 2-hourly
# VIBE_PAPER_TICK_SCHEDULE/VIBE_PAPER_TICK_INTERVAL=1H pair above for
# intraday risk management) and the quota rationale.

# ---- Event trigger (two-tier-cadence Task 3) ----
# Deterministic, LLM-free check run inside EVERY paper tick (no extra job): for
# each watched symbol (open positions + VIBE_COMMITTEE_SYMBOLS) it fetches the
# live price + funding and, on a material move, flags the symbol so the
# paper-trading-tick job fires an ad-hoc crypto_committee run on it (at
# VIBE_COMMITTEE_TIMEFRAME). A per-symbol cooldown makes a sustained move
# trigger exactly once. NOTE: VIBE_EVENT_PRICE_MOVE_PCT defaults ON (5), so a
# plain paper deployment already fires price-move triggers and now creates
# tick_state.json (for event bookkeeping) even in 1D mode; set both thresholds
# to 0 to fully disable the event path (byte-identical to no tick_state in 1D).
# Price-move threshold: |price - reference| / |reference| as a PERCENT. The
# reference is the last committee decision's execution price for the symbol
# (ledger fill, else the journal ref price), else the previous tick's price.
# 0 = disabled. Default 5.
# VIBE_EVENT_PRICE_MOVE_PCT=5
# Funding-rate threshold: |current funding rate| (OKX perpetual, ~per 8h).
# 0.001 = 0.1%/8h. 0 = disabled. Default 0.001.
# VIBE_EVENT_FUNDING_ABS=0.001
# Per-symbol cooldown in HOURS: a symbol that triggered is not re-flagged until
# this window elapses (the only rate limiter — worst case ~2 extra committee
# runs/symbol/day at the 12h default). Default 12.
# VIBE_EVENT_COOLDOWN_H=12

# Enable reasoning on relays that require opt-in (e.g. OpenRouter thinking models).
# Forwarded as extra_body.reasoning.effort = low / medium / high / max.
# Leave unset for Moonshot / DeepSeek official APIs — they return reasoning_content by default.
# LANGCHAIN_REASONING_EFFORT=medium

# ============================================================================
# Data Sources
# ============================================================================
# A-shares: Tushare Pro token (https://tushare.pro)
TUSHARE_TOKEN=your-tushare-token
# HK/US equities: yfinance (free, no config needed)
# Crypto: OKX public API (free, no config needed)
# Crypto fallback exchange (default: binance). Change if OKX is blocked:
# CCXT_EXCHANGE=binance
# HK / A-share equities via Futu OpenAPI (optional, requires FutuOpenD running locally)
# Download FutuOpenD: https://www.futunn.com/download/openAPI
# FUTU_HOST=127.0.0.1
# FUTU_PORT=11111
# Free direct-API sources need NO key and auto-join the fallback chain: Eastmoney / Sina / Stooq / Yahoo.

# Optional API-key data sources (enabled only when the key is set; silently skipped otherwise)
# FINNHUB_API_KEY=xxx         # optional US-equity OHLCV fallback provider (selectable get_market_data source)
# ALPHAVANTAGE_API_KEY=xxx    # optional US-equity OHLCV fallback provider (selectable get_market_data source)
# TIINGO_API_KEY=xxx          # optional US-equity OHLCV fallback provider (selectable get_market_data source)
# FMP_API_KEY=xxx             # optional US-equity OHLCV fallback provider (selectable get_market_data source)
# FRED_API_KEY=xxx            # macro series (get_macro_series tool)
# VIBE_TRADING_IWENCAI_KEY=xxx  # A-share natural-language research search (iwencai_search tool)
# VIBE_TRADING_SEC_UA="Your Name your@email.com"  # SEC EDGAR compliant contact User-Agent (optional; a built-in default UA also works)
# Optional per-source request-spacing overrides for batch jobs — VIBE_TRADING_{EASTMONEY,SINA,STOOQ,YAHOO,SEC,FINNHUB,ALPHAVANTAGE,TIINGO,FMP,FRED,IWENCAI,THS}_MIN_INTERVAL (seconds).

# Opt-in local market-data cache for backtest loaders (off by default).
# When enabled, every data source caches settled historical bars under
# ~/.vibe-trading/cache/loaders/ so repeated/long-horizon backtests skip the
# network. Only fully-elapsed days are cached (ranges ending today are always
# re-fetched). Clear it any time with: rm -rf ~/.vibe-trading/cache
# VIBE_TRADING_DATA_CACHE=1

# ============================================================================
# API Server (optional)
# ============================================================================
# Bearer token for API auth.
# Empty dev mode is loopback-only. Set this before exposing port 8899 beyond localhost.
# API_AUTH_KEY=
# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
# Enable session runtime
# ENABLE_SESSION_RUNTIME=true
# Docker compose sets this together with a 127.0.0.1 port bind so browser
# requests from the host machine still count as local dev-mode access.
# Do not enable this when publishing port 8899 on 0.0.0.0 without API_AUTH_KEY.
# VIBE_TRADING_TRUST_DOCKER_LOOPBACK=0
# Advanced local-only opt-in: expose shell execution tools to the agent.
# VIBE_TRADING_ENABLE_SHELL_TOOLS=0
# Optional import roots for read_document/analyze_trade_journal.
# Use comma-separated absolute paths. Defaults include agent/uploads, agent/runs,
# ./uploads, ./data, ~/.vibe-trading/uploads, and ~/.vibe-trading/imports.
# VIBE_TRADING_ALLOWED_FILE_ROOTS=
# Optional run roots for generated-code tools such as write_file/backtest.
# Defaults include agent/runs, ./runs, and ~/.vibe-trading/shadow_runs.
# VIBE_TRADING_ALLOWED_RUN_ROOTS=

# ============================================================================
# Agent Tuning (optional, defaults are sensible)
# ============================================================================
# SWARM_WORKER_TIMEOUT=300
# SWARM_WORKER_MAX_ITER=50
# Keep the swarm pool at the LLM cap (Phase 2 §4.2) so threads don't exist only
# to block on the global gate. Belt-and-suspenders with VIBE_LLM_MAX_CONCURRENT.
SWARM_MAX_WORKERS=3
# SWARM_TIMEOUT=1800
# SUBAGENT_TIMEOUT=300
# SUBAGENT_MAX_ITER=25
# TOKEN_THRESHOLD=40000
# Hard timeout (seconds) for read-only tool execution; write tools only warn.
# Default 1800; set 0 to disable.
# VIBE_TRADING_TOOL_TIMEOUT_SECONDS=1800
# Frontend SSE idle timeout in seconds before showing "Execution timed out".
# Increase when using slow local models (e.g. Ollama on CPU/limited VRAM).
# VIBE_TRADING_SSE_TIMEOUT=90
# Content filter warning threshold (default: 0.05 = 5%)
# When the ratio of LLM responses blocked by content moderation exceeds this
# threshold, the run card will warn you to switch providers.
# CONTENT_FILTER_WARNING_THRESHOLD=0.05
